{
  "bank_profile": "banorte_enlace_global",
  "profile_version": "v1",
  "document_type": "estado_de_cuenta",
  "bank_name": "Banorte",
  "detect_markers": ["ENLACE GLOBAL PM", "MONTO DEL DEPOSITO"],
  "anchor_regex": "^(\\d{2}-[A-Z]{3}-\\d{2})(.*)",
  "date_format": "%d-%b-%y",
  "date_locale_fix": {
    "ENE": "JAN", "FEB": "FEB", "MAR": "MAR", "ABR": "APR",
    "MAY": "MAY", "JUN": "JUN", "JUL": "JUL", "AGO": "AUG",
    "SEP": "SEP", "OCT": "OCT", "NOV": "NOV", "DIC": "DEC"
  },
  "amount_strategy": "single_column_two_amounts_right_aligned",
  "saldo_position": "last_money_value_in_anchor_line",
  "saldo_required_each_row": true,
  "holder_name_regex": "^([A-ZÁÉÍÓÚÑ][A-ZÁÉÍÓÚÑ\\s&,.]{9,149})",
  "clabe_regex": "CLABE[:\\s]+([0-9]{18})",
  "rastreo_regex": "CVE\\s*RAST(?:REO)?\\s*[:\\s]+([A-Za-z0-9]+)",
  "referencia_regex": "REFERENCIA\\s*[:\\s]+([A-Za-z0-9]+)",
  "origen_clabe_regex": "CLABE\\s+Ord[\\s:]+([0-9]{15,18})",
  "destino_clabe_regex": "CLABE\\s+Ben[\\s:]+([0-9]{15,18})",
  "origen_nombre_regex": "Nombre\\s+Ord[\\s:]+([^\\n]{3,80})",
  "destino_nombre_regex": "Nombre\\s+Ben[\\s:]+([^\\n]{3,80})",
  "summary_deposits_regex": "Total\\s+de\\s+dep[oó]sitos\\s+\\$?\\s*([0-9,]+\\.\\d{2})",
  "summary_withdrawals_regex": "Total\\s+de\\s+retiros\\s+\\$?\\s*([0-9,]+\\.\\d{2})",
  "period_regex": "Del\\s+(\\d{2}-[A-Z]{3}-\\d{2})\\s+[Aa]l\\s+(\\d{2}-[A-Z]{3}-\\d{2})",
  "account_regex": "Cuenta[:\\s]+([*\\d]+)",
  "skip_line_patterns": ["^SALDO ANTERIOR", "^OTROS", "^Cargos Objetados", "^TOTAL"]
}
