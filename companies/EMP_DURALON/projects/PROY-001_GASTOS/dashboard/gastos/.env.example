# URL del backend factory3 (Render o reemplazo futuro)
# Sin credenciales de Supabase en Vercel: factory3 las maneja internamente.
FACTORY_API_URL=https://factory3.onrender.com

# Opcional. Si se configura en factory3 como CLIENT_EXPENSES_DASHBOARD_KEY,
# Vercel debe enviar el mismo valor como header server-side X-Dashboard-Key.
DASHBOARD_KEY=
