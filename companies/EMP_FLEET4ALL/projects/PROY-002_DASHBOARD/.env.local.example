# Factory3 backend (Render)
FACTORY_API_URL=https://factory3.onrender.com
FACTORY_API_SECRET=mismo_valor_que_FACTORY_API_SECRET_en_Render

# Apps4All portal (SSO) — debe apuntar al portal ya autenticado, no al login
NEXT_PUBLIC_APPS4ALL_URL=https://apps4all-zeta.vercel.app

# JWT — mismo valor que PLATFORM_JWT_SECRET en Render
PLATFORM_JWT_SECRET=tu_hex_de_64_chars

# Supabase del proyecto platform (grants/access control) — separado del Supabase principal
PLATFORM_SUPABASE_URL=
PLATFORM_SUPABASE_SERVICE_ROLE_KEY=
